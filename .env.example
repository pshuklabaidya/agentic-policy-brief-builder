# Copy this file to .env for local development.
# Never commit real secrets. .env and .streamlit/secrets.toml are gitignored.

# Required: OpenAI API key for model and embedding requests.
OPENAI_API_KEY=

# Optional: override model choices used by the app.
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: local, test, staging, or production.
APP_ENV=local

# Optional: local vector-store persistence directory.
VECTOR_STORE_DIR=.chroma
